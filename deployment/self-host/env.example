# Release bundles supply ROWSET_IMAGE by default; explicit immutable overrides remain supported.
ROWSET_IMAGE=
ROWSET_DOMAIN=

# Required production mode
ENVIRONMENT=prod
DEBUG=off

# Required application and service secrets; init-env.sh fills these once.
SECRET_KEY=
POSTGRES_DB=rowset
POSTGRES_USER=rowset
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional account and email integrations
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MAILGUN_API_KEY=

# Optional observability
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_BROWSER_HOST=
POSTHOG_LOGS_ENABLED=False

# Optional private asset storage
ROWSET_ASSET_S3_ENDPOINT_URL=
ROWSET_ASSET_STORAGE_BUCKET_NAME=
ROWSET_ASSET_ACCESS_KEY_ID=
ROWSET_ASSET_SECRET_ACCESS_KEY=
ROWSET_ASSET_REGION_NAME=auto

# Coordinated backups (local retention is always enabled; S3 is optional)
ROWSET_BACKUP_RETENTION_DAYS=7
ROWSET_BACKUP_S3_ENDPOINT_URL=
ROWSET_BACKUP_S3_BUCKET=
ROWSET_BACKUP_S3_ACCESS_KEY_ID=
ROWSET_BACKUP_S3_SECRET_ACCESS_KEY=
ROWSET_BACKUP_S3_REGION=auto
ROWSET_BACKUP_S3_PREFIX=rowset

# Optional semantic search
ROWSET_VECTOR_SEARCH_ENABLED=False
QDRANT_URL=
QDRANT_API_KEY=
OPENROUTER_API_KEY=
